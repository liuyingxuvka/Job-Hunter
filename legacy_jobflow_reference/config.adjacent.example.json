{
  "candidate": {
    "resumePath": "./resume.md",
    "scopeProfile": "adjacent_mbse",
    "targetRole": "Adjacent-track systems, MBSE, verification, integration, reliability, or digital engineering roles that can reuse an experienced candidate's existing strengths.",
    "locationPreference": "Primary and secondary target regions defined by the user. Remote or relocation depends on the candidate."
  },
  "search": {
    "model": "gpt-4o-mini",
    "maxJobsPerQuery": 40,
    "regionMode": "global_open",
    "feedbackWeightEnabled": true,
    "allowPlatformListings": true,
    "platformListingDomains": [
      "linkedin.com"
    ],
    "trackMix": {
      "systems_engineering": 0.4,
      "verification_reliability": 0.35,
      "digital_engineering": 0.25
    },
    "queries": [
      "MBSE engineer energy systems job",
      "requirements verification engineer complex systems job",
      "systems integration engineer industrial equipment job",
      "reliability engineer advanced manufacturing job",
      "digital twin engineer asset health job",
      "technical interface engineer complex products job"
    ],
    "blockedDomains": [
      "linkedin.com",
      "indeed.com",
      "glassdoor.com",
      "monster.com",
      "ziprecruiter.com"
    ],
    "allowedDomains": []
  },
  "sources": {
    "enableWebSearch": true,
    "enableCompanySources": true,
    "requireCompanyDiscovery": true,
    "companiesPath": "./companies_adjacent.json",
    "maxCompaniesPerRun": 120,
    "maxJobsPerCompany": 40,
    "maxJobLinksPerCompany": 40,
    "preferMajorCompanies": true,
    "rotateCompanyWindow": true,
    "majorCompanyPinnedCount": 24,
    "companyRotationIntervalDays": 1,
    "enableCompanySearchFallback": true,
    "maxCompanySearchFallbacksPerRun": 12,
    "fallbackSearchRegions": [
      "region:EU",
      "region:US",
      "region:APAC"
    ],
    "priorityRegionWeights": {
      "region:EU": 60,
      "region:US": 50,
      "region:APAC": 40
    },
    "majorCompanyKeywords": [
      "example mobility systems",
      "sample automation group",
      "contoso digital engineering"
    ],
    "cnHydrogenCompanyKeywords": []
  },
  "companyDiscovery": {
    "model": "gpt-4o-mini",
    "enableAutoDiscovery": true,
    "maxNewCompaniesPerRun": 40,
    "maxCompaniesPerQuery": 15,
    "queries": [
      "MBSE and systems engineering companies careers",
      "verification and validation engineering companies careers",
      "industrial digital twin companies careers",
      "reliability engineering companies official careers"
    ]
  },
  "fetch": {
    "timeoutMs": 20000,
    "userAgent": "jobflow/1.0"
  },
  "filters": {
    "maxPostAgeDays": 180,
    "excludeUnavailableLinks": true,
    "outputLinkRecheckHours": 72,
    "excludeAggregatorLinks": true,
    "preferDirectEmployerSite": true,
    "extraBlockedDomains": [
      "echojobs.io",
      "jobsora.com",
      "jooble.org",
      "talent.com"
    ]
  },
  "analysis": {
    "model": "gpt-4o",
    "strictScoring": false,
    "maxJobsToAnalyzePerRun": 160,
    "preFilterEnabled": true,
    "preFilterScoreThreshold": 40,
    "lowTokenMode": true,
    "scoringUseWebSearch": false,
    "scoringJdMaxChars": 12000,
    "lowTokenJdMaxChars": 1800,
    "postVerifyEnabled": true,
    "postVerifyRequireChecked": true,
    "postVerifyModel": "gpt-4o-mini",
    "postVerifyUseWebSearch": true,
    "postVerifyMaxJobsPerRun": 60,
    "postVerifyJdMaxChars": 1000,
    "transferableFitEnabled": true,
    "recommendScoreThreshold": 58,
    "minTransferableScore": 52,
    "platformListingRecommendScoreThreshold": 68
  },
  "translation": {
    "enable": false,
    "model": "gpt-4o-mini",
    "target": "zh-CN"
  },
  "output": {
    "trackerXlsxPath": "./jobs_adjacent.xlsx",
    "xlsxPath": "./jobs_adjacent.xlsx",
    "jsonPath": "./jobs_adjacent_all.json",
    "foundJsonPath": "./jobs_adjacent_found.json",
    "recommendedXlsxPath": "./jobs_adjacent.xlsx",
    "recommendedJsonPath": "./jobs_adjacent_recommended.json",
    "cnEuropeJsonPath": "./jobs_adjacent_cn_europe.json",
    "recommendedMode": "append"
  }
}
