{
  "candidate": {
    "resumePath": "./resume.md",
    "scopeProfile": "hydrogen_mainline",
    "targetRole": "Experienced systems, validation, reliability, or domain-specialist roles in advanced energy and industrial technology.",
    "locationPreference": "Primary and secondary target regions defined by the user. Remote or relocation depends on the candidate."
  },
  "search": {
    "model": "gpt-4o-mini",
    "maxJobsPerQuery": 40,
    "regionMode": "global_open",
    "feedbackWeightEnabled": true,
    "allowPlatformListings": true,
    "platformListingDomains": [
      "linkedin.com"
    ],
    "trackMix": {
      "core_domain": 0.5,
      "adjacent_domain": 0.3,
      "systems_validation": 0.2
    },
    "queries": [
      "systems integration engineer advanced energy job",
      "reliability engineer industrial systems job",
      "verification validation engineer energy equipment job",
      "digital twin engineer industrial technology job",
      "condition monitoring engineer energy systems job",
      "advanced manufacturing systems engineer job"
    ],
    "blockedDomains": [
      "linkedin.com",
      "indeed.com",
      "glassdoor.com",
      "monster.com",
      "ziprecruiter.com"
    ],
    "allowedDomains": []
  },
  "sources": {
    "enableWebSearch": true,
    "enableCompanySources": true,
    "requireCompanyDiscovery": true,
    "companiesPath": "./companies.json",
    "maxCompaniesPerRun": 120,
    "maxJobsPerCompany": 40,
    "maxJobLinksPerCompany": 40,
    "preferMajorCompanies": true,
    "rotateCompanyWindow": true,
    "majorCompanyPinnedCount": 24,
    "companyRotationIntervalDays": 1,
    "enableCompanySearchFallback": true,
    "maxCompanySearchFallbacksPerRun": 12,
    "fallbackSearchRegions": [
      "region:EU",
      "region:US",
      "region:APAC"
    ],
    "priorityRegionWeights": {
      "region:EU": 60,
      "region:US": 50,
      "region:APAC": 40
    },
    "majorCompanyKeywords": [
      "example energy systems",
      "sample industrial technology",
      "contoso reliability labs"
    ],
    "cnHydrogenCompanyKeywords": []
  },
  "companyDiscovery": {
    "model": "gpt-4o-mini",
    "enableAutoDiscovery": true,
    "maxNewCompaniesPerRun": 40,
    "maxCompaniesPerQuery": 15,
    "queries": [
      "advanced energy systems companies careers",
      "industrial reliability engineering companies careers",
      "systems integration companies official careers",
      "digital twin and asset health companies careers"
    ]
  },
  "fetch": {
    "timeoutMs": 20000,
    "userAgent": "jobflow/1.0"
  },
  "filters": {
    "maxPostAgeDays": 180,
    "excludeUnavailableLinks": true,
    "outputLinkRecheckHours": 72,
    "excludeAggregatorLinks": true,
    "preferDirectEmployerSite": true,
    "extraBlockedDomains": [
      "echojobs.io",
      "jobsora.com",
      "jooble.org",
      "talent.com"
    ]
  },
  "analysis": {
    "model": "gpt-4o",
    "strictScoring": false,
    "maxJobsToAnalyzePerRun": 160,
    "preFilterEnabled": true,
    "preFilterScoreThreshold": 40,
    "lowTokenMode": true,
    "scoringUseWebSearch": false,
    "scoringJdMaxChars": 12000,
    "lowTokenJdMaxChars": 1800,
    "postVerifyEnabled": true,
    "postVerifyRequireChecked": true,
    "postVerifyModel": "gpt-4o-mini",
    "postVerifyUseWebSearch": true,
    "postVerifyMaxJobsPerRun": 60,
    "postVerifyJdMaxChars": 1000,
    "transferableFitEnabled": true,
    "recommendScoreThreshold": 60,
    "minTransferableScore": 55,
    "platformListingRecommendScoreThreshold": 68
  },
  "companyFit": {
    "enabled": true,
    "model": "gpt-4o-mini",
    "maxCompaniesToEvaluate": 18,
    "batchSize": 6
  },
  "translation": {
    "enable": false,
    "model": "gpt-4o-mini",
    "target": "zh-CN"
  },
  "output": {
    "trackerXlsxPath": "./jobs_recommended.xlsx",
    "xlsxPath": "./jobs.xlsx",
    "jsonPath": "./jobs.json",
    "foundJsonPath": "./jobs_found.json",
    "recommendedXlsxPath": "./jobs_recommended.xlsx",
    "recommendedJsonPath": "./jobs_recommended.json",
    "cnEuropeJsonPath": "./jobs_cn_europe.json",
    "recommendedMode": "append"
  }
}
